<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Career Pipeline — Yohann OS</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Crimson+Pro:ital,wght@0,300;0,400;1,300;1,400&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#080808;--s1:#0f0f0f;--s2:#161616;--s3:#1e1e1e;
  --b1:rgba(255,255,255,0.06);--b2:rgba(255,255,255,0.12);--b3:rgba(255,255,255,0.2);
  --t1:#e8e4dc;--t2:#7a7670;--t3:#3d3a36;
  --green:#1a8c63;--gb:#22b07d;--gdim:rgba(26,140,99,0.12);--gbdr:rgba(26,140,99,0.35);
  --amber:#c49a3c;--adim:rgba(196,154,60,0.1);--abdr:rgba(196,154,60,0.3);
  --coral:#c0553a;--cdim:rgba(192,85,58,0.1);--cbdr:rgba(192,85,58,0.3);
  --purple:#6e65c4;--pdim:rgba(110,101,196,0.1);--pbdr:rgba(110,101,196,0.3);
  --blue:#3a7bc4;--bdim:rgba(58,123,196,0.1);--bbdr:rgba(58,123,196,0.3);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--t1);font-family:'JetBrains Mono',monospace;font-size:13px;line-height:1.6;min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:9999;opacity:0.35}

#loader{position:fixed;inset:0;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9998;transition:opacity 0.8s ease,visibility 0.8s}
#loader.hidden{opacity:0;visibility:hidden}
.l-name{font-family:'Bebas Neue',sans-serif;font-size:clamp(40px,10vw,88px);letter-spacing:0.15em;animation:lpulse 1.5s ease-in-out infinite alternate}
.l-sub{font-size:10px;color:var(--t3);letter-spacing:0.3em;text-transform:uppercase;margin-top:8px}
.l-bar-wrap{width:160px;height:1px;background:var(--b2);margin-top:28px;overflow:hidden}
.l-bar{height:100%;background:var(--gb);width:0%;animation:lbar 1.8s ease forwards}
@keyframes lpulse{from{opacity:0.4}to{opacity:1}}
@keyframes lbar{0%{width:0%}60%{width:70%}100%{width:100%}}

.app{max-width:900px;margin:0 auto;padding:0 28px 100px;opacity:0;animation:fadein 0.6s ease 2s forwards}
@keyframes fadein{to{opacity:1}}

.header{padding:44px 0 24px;border-bottom:1px solid var(--b1);margin-bottom:32px;display:flex;align-items:flex-end;justify-content:space-between;gap:20px}
.h-wordmark{font-family:'Bebas Neue',sans-serif;font-size:clamp(36px,6vw,64px);letter-spacing:0.12em;line-height:1}
.h-sub{font-family:'Crimson Pro',serif;font-style:italic;font-size:15px;color:var(--t2);margin-top:6px}
.h-right{text-align:right;flex-shrink:0}
.h-date{font-size:10px;color:var(--t3);letter-spacing:0.12em;text-transform:uppercase}
.h-back{font-size:9px;color:var(--t3);letter-spacing:0.14em;text-transform:uppercase;border:1px solid var(--b1);padding:4px 10px;cursor:pointer;background:transparent;font-family:'JetBrains Mono',monospace;transition:all 0.15s;display:inline-block;margin-bottom:6px}
.h-back:hover{border-color:var(--b2);color:var(--t2)}

/* STATS */
.stats{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:1px;background:var(--b1);border:1px solid var(--b1);margin-bottom:28px}
.stat{background:var(--s1);padding:14px 16px}
.stat-l{font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:var(--t3);margin-bottom:5px}
.stat-v{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:0.05em;color:var(--t1);line-height:1}
.stat-v.g{color:var(--gb)}.stat-v.a{color:var(--amber)}.stat-v.c{color:var(--coral)}
.stat-s{font-size:10px;color:var(--t3);margin-top:2px}

/* PROGRESS RING AREA */
.monthly-wrap{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--b1);border:1px solid var(--b1);margin-bottom:28px}
.monthly-cell{background:var(--s1);padding:16px}
.monthly-label{font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:var(--t3);margin-bottom:10px}
.monthly-bar-meta{display:flex;justify-content:space-between;font-size:10px;color:var(--t3);margin-bottom:5px}
.monthly-bar-wrap{height:3px;background:var(--s3);overflow:hidden}
.monthly-bar-fill{height:100%;transition:width 0.5s ease}

/* FUNNEL */
.funnel{display:flex;gap:2px;margin-bottom:28px}
.funnel-stage{flex:1;background:var(--s1);border:1px solid var(--b1);padding:14px 12px;text-align:center;cursor:pointer;transition:all 0.15s;position:relative}
.funnel-stage:hover{background:var(--s2)}
.funnel-stage.active-filter{border-color:var(--b2);background:var(--s2)}
.funnel-stage::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:transparent;transition:background 0.15s}
.funnel-stage.active-filter::after{background:var(--amber)}
.fs-count{font-family:'Bebas Neue',sans-serif;font-size:32px;letter-spacing:0.05em;line-height:1;margin-bottom:4px}
.fs-label{font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:var(--t3)}

/* SLBL */
.slbl{font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:var(--t3);margin-bottom:14px;display:flex;align-items:center;gap:12px}
.slbl::after{content:'';flex:1;height:1px;background:var(--b1)}

/* ADD FORM */
.add-form{background:var(--s1);border:1px solid var(--b1);padding:20px;margin-bottom:28px}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.form-full{grid-column:1/-1}
.flbl{font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:var(--t3);margin-bottom:5px}
input[type="text"],input[type="date"],select,textarea{width:100%;background:var(--s2);border:1px solid var(--b1);padding:9px 12px;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--t1);transition:border-color 0.15s}
input[type="text"]:focus,input[type="date"]:focus,select:focus,textarea:focus{outline:none;border-color:var(--b2)}
input::placeholder,textarea::placeholder{color:var(--t3)}
select{cursor:pointer}
select option{background:var(--s2);color:var(--t1)}
textarea{min-height:60px;resize:vertical;font-size:12px;line-height:1.5}

.btn{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:0.14em;text-transform:uppercase;padding:10px 18px;border:1px solid var(--b2);background:transparent;color:var(--t2);cursor:pointer;transition:all 0.15s;display:inline-flex;align-items:center;gap:6px}
.btn:hover{border-color:var(--gb);color:var(--gb)}
.btn.active-stage{border-color:var(--gbdr);color:var(--gb);background:var(--gdim)}
.btn.danger:hover{border-color:var(--cbdr);color:var(--coral)}
.btn.amber:hover{border-color:var(--abdr);color:var(--amber)}
.btn-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:12px}

/* PIPELINE CARDS */
.pipe-list{display:flex;flex-direction:column;gap:2px}
.pipe-card{background:var(--s1);border:1px solid var(--b1);transition:all 0.15s;position:relative;overflow:hidden}
.pipe-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px}
.pipe-card.stage-applied::before{background:var(--blue)}
.pipe-card.stage-screen::before{background:var(--amber)}
.pipe-card.stage-interview::before{background:var(--purple)}
.pipe-card.stage-waiting::before{background:var(--coral)}
.pipe-card.stage-offer::before{background:var(--gb)}
.pipe-card.stage-rejected::before{background:var(--t3);opacity:0.3}
.pipe-card.stage-rejected{opacity:0.5}
.pipe-header{display:flex;align-items:center;gap:14px;padding:14px 16px 14px 20px;cursor:pointer}
.pipe-header:hover .pipe-company{color:var(--t1)}
.pipe-company{font-size:14px;font-weight:400;color:var(--t1);flex:1;min-width:0;transition:color 0.15s}
.pipe-role{font-size:10px;color:var(--t2);margin-top:2px}
.pipe-sector{font-size:9px;color:var(--t3);margin-top:1px}
.stage-badge{font-size:9px;letter-spacing:0.1em;text-transform:uppercase;padding:3px 10px;border:1px solid;flex-shrink:0}
.badge-applied{border-color:var(--bbdr);color:var(--blue)}
.badge-screen{border-color:var(--abdr);color:var(--amber)}
.badge-interview{border-color:var(--pbdr);color:var(--purple)}
.badge-waiting{border-color:var(--cbdr);color:var(--coral)}
.badge-offer{border-color:var(--gbdr);color:var(--gb)}
.badge-rejected{border-color:var(--b1);color:var(--t3)}
.priority-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.p-high{background:var(--coral)}.p-med{background:var(--amber)}.p-low{background:var(--t3)}

.pipe-body{display:none;padding:0 20px 16px 20px;border-top:1px solid var(--b1)}
.pipe-card.open .pipe-body{display:block}
.pipe-meta{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-top:14px;margin-bottom:14px}
.pm-item{}
.pm-label{font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:var(--t3);margin-bottom:3px}
.pm-val{font-size:12px;color:var(--t2)}
.pipe-notes{font-family:'Crimson Pro',serif;font-size:15px;color:var(--t2);line-height:1.5;margin-top:10px;padding-top:10px;border-top:1px solid var(--b1)}
.follow-alert{font-size:10px;padding:6px 10px;background:var(--cdim);border:1px solid var(--cbdr);color:var(--coral);margin-bottom:10px;display:inline-flex;align-items:center;gap:6px}

/* SORT/FILTER */
.controls{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;align-items:center}
.ctrl-btn{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:0.1em;text-transform:uppercase;padding:5px 12px;border:1px solid var(--b1);background:transparent;color:var(--t3);cursor:pointer;transition:all 0.15s}
.ctrl-btn:hover{border-color:var(--b2);color:var(--t2)}
.ctrl-btn.active{border-color:var(--b2);color:var(--t1)}
.ctrl-sep{color:var(--t3);font-size:10px}

/* TARGETS */
.target-row{display:flex;align-items:center;gap:0;background:var(--b1);margin-bottom:2px}
.tgt-label{background:var(--s1);padding:12px 16px;font-size:11px;color:var(--t2);min-width:200px;border-right:1px solid var(--b1)}
.tgt-bar-wrap{flex:1;background:var(--s1);padding:12px 16px;border-right:1px solid var(--b1)}
.tgt-track{height:3px;background:var(--s3)}
.tgt-fill{height:100%;transition:width 0.5s ease}
.tgt-val{background:var(--s1);padding:12px 16px;font-family:'Bebas Neue',sans-serif;font-size:18px;min-width:80px;text-align:right}

/* TARGET SECTORS */
.sector-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:2px;margin-bottom:28px}
.sector-card{background:var(--s1);border:1px solid var(--b1);padding:14px;transition:all 0.15s}
.sector-card:hover{background:var(--s2)}
.sector-name{font-size:12px;font-weight:400;color:var(--t1);margin-bottom:4px}
.sector-why{font-size:11px;color:var(--t3);line-height:1.4;font-family:'Crimson Pro',serif;font-style:italic}

/* ROLE PRIORITY */
.role-row{display:flex;align-items:center;gap:14px;padding:12px 16px;background:var(--s1);border:1px solid var(--b1);margin-bottom:2px}
.role-priority{font-size:9px;letter-spacing:0.1em;text-transform:uppercase;padding:2px 8px;border:1px solid;min-width:60px;text-align:center;flex-shrink:0}
.rp-high{border-color:var(--gbdr);color:var(--gb)}
.rp-med{border-color:var(--abdr);color:var(--amber)}
.rp-low{border-color:var(--b1);color:var(--t3)}
.role-name{font-size:13px;color:var(--t1);flex:1}
.role-why{font-size:10px;color:var(--t3);margin-top:2px;font-family:'Crimson Pro',serif;font-style:italic}

/* TEMPLATES */
.template-card{background:var(--s1);border:1px solid var(--b1);padding:16px;margin-bottom:2px}
.template-title{font-size:11px;color:var(--amber);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:8px}
.template-body{font-family:'Crimson Pro',serif;font-size:15px;color:var(--t2);line-height:1.7}
.copy-btn{font-size:9px;letter-spacing:0.1em;text-transform:uppercase;padding:4px 10px;border:1px solid var(--b1);background:transparent;color:var(--t3);cursor:pointer;font-family:'JetBrains Mono',monospace;margin-top:10px;transition:all 0.15s;display:inline-block}
.copy-btn:hover{border-color:var(--abdr);color:var(--amber)}
.copy-btn.copied{border-color:var(--gbdr);color:var(--gb)}

/* NAV */
.tab-nav{display:flex;gap:2px;margin-bottom:32px;border-bottom:1px solid var(--b1);overflow-x:auto;scrollbar-width:none}
.tab-nav::-webkit-scrollbar{display:none}
.tnb{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:0.14em;text-transform:uppercase;padding:11px 16px;border:none;background:transparent;color:var(--t3);cursor:pointer;white-space:nowrap;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all 0.2s}
.tnb:hover{color:var(--t2)}
.tnb.active{color:var(--gb);border-bottom-color:var(--gb)}
.tab{display:none}.tab.active{display:block}

.rule{border:none;border-top:1px solid var(--b1);margin:24px 0}
.empty{font-family:'Crimson Pro',serif;font-style:italic;font-size:14px;color:var(--t3);padding:20px 0}
</style>
</head>
<body>

<div id="loader">
  <div class="l-name">Pipeline</div>
  <div class="l-sub">Career Operating System</div>
  <div class="l-bar-wrap"><div class="l-bar"></div></div>
</div>

<div class="app">

<header class="header">
  <div>
    <div class="h-wordmark">Career Pipeline</div>
    <div class="h-sub">The first job funds the build. Mid-size corporate finance, FP&A, Strategy, BA — 20 apps/month, 12 outreaches/month.</div>
  </div>
  <div class="h-right">
    <div class="h-date" id="hdr-date"></div>
  </div>
</header>

<!-- STATS -->
<div class="stats" id="main-stats"></div>

<!-- MONTHLY TARGETS -->
<div class="monthly-wrap" id="monthly-wrap"></div>

<!-- FUNNEL -->
<div class="slbl">Funnel — click to filter</div>
<div class="funnel" id="funnel"></div>

<!-- TABS -->
<div class="tab-nav">
  <button class="tnb active" data-tab="pipeline" onclick="switchTab(this)">Pipeline</button>
  <button class="tnb" data-tab="add" onclick="switchTab(this)">Add application</button>
  <button class="tnb" data-tab="roles" onclick="switchTab(this)">Role targets</button>
  <button class="tnb" data-tab="sectors" onclick="switchTab(this)">Target sectors</button>
  <button class="tnb" data-tab="templates" onclick="switchTab(this)">Outreach templates</button>
</div>

<!-- PIPELINE TAB -->
<div id="tab-pipeline" class="tab active">
  <div class="controls">
    <span style="font-size:9px;color:var(--t3);letter-spacing:0.1em;text-transform:uppercase">Sort:</span>
    <button class="ctrl-btn active" onclick="setSort('date',this)">Date added</button>
    <button class="ctrl-btn" onclick="setSort('stage',this)">Stage</button>
    <button class="ctrl-btn" onclick="setSort('company',this)">Company</button>
    <button class="ctrl-btn" onclick="setSort('followup',this)">Follow-up</button>
    <span class="ctrl-sep">|</span>
    <button class="ctrl-btn" onclick="setSort('all',this);activeFilter='all';renderPipeline()">Show all</button>
  </div>
  <div class="pipe-list" id="pipe-list"></div>
  <div class="rule"></div>
  <button class="btn" onclick="exportData()">&#8595; Export backup</button>
  &nbsp;<label class="btn" style="cursor:pointer">&#8593; Import<input type="file" accept=".json" style="display:none" onchange="importData(this)"></label>
</div>

<!-- ADD TAB -->
<div id="tab-add" class="tab">
  <div class="add-form">
    <div class="form-grid">
      <div>
        <div class="flbl">Company *</div>
        <input type="text" id="f-company" placeholder="Company name">
      </div>
      <div>
        <div class="flbl">Role title *</div>
        <input type="text" id="f-role" placeholder="e.g. FP&A Analyst">
      </div>
      <div>
        <div class="flbl">Role type</div>
        <select id="f-type">
          <option value="fpa">FP&A Analyst</option>
          <option value="strategy">Strategy Analyst</option>
          <option value="ba">Business Analyst</option>
          <option value="pricing">Pricing Analyst</option>
          <option value="corpdev">Corporate Development Analyst</option>
          <option value="valuation">Valuation Analyst</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <div class="flbl">Stage</div>
        <select id="f-stage">
          <option value="applied">Applied</option>
          <option value="screen">Phone Screen</option>
          <option value="interview">Interview</option>
          <option value="waiting">Waiting on response</option>
          <option value="offer">Offer</option>
          <option value="rejected">Rejected</option>
        </select>
      </div>
      <div>
        <div class="flbl">Sector</div>
        <select id="f-sector">
          <option value="Insurance">Insurance</option>
          <option value="Healthcare">Healthcare Services</option>
          <option value="Tech/SaaS">Tech / SaaS</option>
          <option value="Logistics">Logistics</option>
          <option value="Industrial">Industrial / Manufacturing</option>
          <option value="Utilities">Utilities</option>
          <option value="Consumer">Consumer / Distribution</option>
          <option value="Financial Services">Financial Services</option>
          <option value="Other">Other</option>
        </select>
      </div>
      <div>
        <div class="flbl">Priority</div>
        <select id="f-priority">
          <option value="high">High</option>
          <option value="med">Medium</option>
          <option value="low">Low</option>
        </select>
      </div>
      <div>
        <div class="flbl">Date applied</div>
        <input type="date" id="f-date">
      </div>
      <div>
        <div class="flbl">Follow-up date</div>
        <input type="date" id="f-followup">
      </div>
      <div>
        <div class="flbl">Contact name</div>
        <input type="text" id="f-contact" placeholder="Recruiter or hiring manager">
      </div>
      <div>
        <div class="flbl">Contact email / LinkedIn</div>
        <input type="text" id="f-contactinfo" placeholder="email or profile URL">
      </div>
      <div class="form-full">
        <div class="flbl">Notes</div>
        <textarea id="f-notes" placeholder="Case study required, referral, interview format, salary range, anything relevant..."></textarea>
      </div>
    </div>
    <button class="btn" onclick="addApp()">+ Add to pipeline</button>
  </div>
</div>

<!-- ROLES TAB -->
<div id="tab-roles" class="tab">
  <div class="slbl">Role hierarchy — your target sequence</div>
  <div id="role-list"></div>
</div>

<!-- SECTORS TAB -->
<div id="tab-sectors" class="tab">
  <div class="slbl">Target sectors — sweet spot companies</div>
  <p style="font-family:'Crimson Pro',serif;font-style:italic;font-size:15px;color:var(--t2);margin-bottom:20px;line-height:1.6">Mid-size companies: established enough to have real finance process, small enough that a junior analyst does real work, not so branded that GPA screens dominate.</p>
  <div class="sector-grid" id="sector-grid"></div>
  <div class="slbl" style="margin-top:8px">Monthly targets</div>
  <div id="target-bars"></div>
</div>

<!-- TEMPLATES TAB -->
<div id="tab-templates" class="tab">
  <div class="slbl">Outreach templates — your exact scripts</div>
  <div id="template-list"></div>
</div>

</div><!-- end app -->

<script>
// ── DATA ──────────────────────────────────────────────────

const ROLE_TARGETS=[
  {priority:"high",name:"Financial Analyst / FP&A Analyst",why:"Directly aligned with degree, Excel, forecasting, variance analysis. Lowest friction to first offer."},
  {priority:"high",name:"Strategy Analyst / Business Analyst",why:"Signals structured thinking, cross-functional exposure. Strong fit for your cognitive edge."},
  {priority:"med",name:"Pricing Analyst / Analytics Analyst",why:"Strong quantitative reps, good if business-facing. Solid second tier."},
  {priority:"med",name:"Valuation Analyst / Corporate Development Analyst",why:"Strong fit if you can get it — lower hit rate given GPA. Target at mid-size firms."},
  {priority:"low",name:"Pure sales, pure operations admin",why:"Wrong ladder. Avoid unless it's a deliberate bridge with a clear upgrade path."},
];

const SECTORS=[
  {name:"Insurance",why:"Stable cash flow, strong FP&A functions, analytical rigor. Elephant Insurance is already in your history."},
  {name:"Healthcare Services",why:"Massive sector, high demand for finance/analytics talent, less GPA-obsessed than finance."},
  {name:"Tech / SaaS",why:"FP&A and BA roles abound, data-forward culture, your Python/regression work lands well."},
  {name:"Logistics",why:"Complex operations = real analytical work. Finance teams are lean and impactful."},
  {name:"Industrial / Manufacturing",why:"Underrated hunting ground. Strong FP&A needs, less competition from prestige-chasers."},
  {name:"Utilities",why:"Stable, analytical, GPA-lenient. Good first-job infrastructure."},
  {name:"Consumer / Distribution",why:"Real variance analysis and forecasting work. FP&A roles are substantive."},
  {name:"Financial Services (mid-size)",why:"Avoid bulge brackets. Target regional banks, insurance firms, asset managers under $5B AUM."},
];

const TEMPLATES=[
  {
    title:"Alumni / analyst outreach",
    body:`Hi [Name] — I'm a VCU finance student building toward corporate finance / FP&A / analytics roles. I've been developing Python-based valuation and analytics projects on GitHub and would value 15 minutes to understand how you broke into your first analytical role and what skills mattered most in your first year. Thank you either way.\n\n— Sam Gebreyohannes`
  },
  {
    title:"Manager / finance team outreach",
    body:`Hi [Name] — I'm a finance student at VCU focused on financial modeling, analytics, and business decision support. I've built public Python projects in valuation and regression analysis and I'm targeting entry-level analyst work where I can contribute in forecasting, modeling, and data-driven problem solving. If your team hires interns or new grads, I'd appreciate the chance to introduce myself and share my work.\n\n— Sam Gebreyohannes`
  },
  {
    title:"After application follow-up",
    body:`Hi [Name] — I recently applied to the [role] position. I'm reaching out because the work lines up directly with the type of analytical responsibilities I've been building toward through finance coursework and self-driven modeling projects. If helpful, I can send a short portfolio summary or GitHub links. Thank you for your time.\n\n— Sam Gebreyohannes`
  },
  {
    title:"Cold LinkedIn connection request",
    body:`Hi [Name] — I'm a VCU finance student targeting FP&A and analytics roles. I noticed your background in [area] and would love to connect. I'm building toward analytical work and would value any perspective you're open to sharing.`
  },
];

const STAGE_LABELS={applied:"Applied",screen:"Phone Screen",interview:"Interview",waiting:"Waiting",offer:"Offer",rejected:"Rejected"};
const STAGE_ORDER={applied:0,screen:1,interview:2,waiting:3,offer:4,rejected:5};
const TYPE_LABELS={fpa:"FP&A Analyst",strategy:"Strategy Analyst",ba:"Business Analyst",pricing:"Pricing Analyst",corpdev:"Corp Dev Analyst",valuation:"Valuation Analyst",other:"Other"};

// ── STORAGE ───────────────────────────────────────────────
function gs(k,def){try{const v=localStorage.getItem(k);return v!==null?JSON.parse(v):def}catch{return def}}
function ss(k,v){try{localStorage.setItem(k,JSON.stringify(v))}catch{}}
function today(){return new Date().toISOString().split("T")[0]}

let pipeline=gs("cp_pipeline",[]);
let activeFilter="all";
let sortMode="date";

// ── HEADER ────────────────────────────────────────────────
document.getElementById("hdr-date").textContent=new Date().toLocaleDateString("en-US",{weekday:"long",month:"long",day:"numeric"}).toUpperCase();

// ── TABS ─────────────────────────────────────────────────
function switchTab(btn){
  document.querySelectorAll(".tnb").forEach(b=>b.classList.remove("active"));
  btn.classList.add("active");
  document.querySelectorAll(".tab").forEach(t=>t.classList.remove("active"));
  document.getElementById("tab-"+btn.dataset.tab).classList.add("active");
  if(btn.dataset.tab==="roles")renderRoles();
  if(btn.dataset.tab==="sectors")renderSectors();
  if(btn.dataset.tab==="templates")renderTemplates();
}

// ── STATS ─────────────────────────────────────────────────
function renderStats(){
  const active=pipeline.filter(p=>p.stage!=="rejected");
  const interviews=pipeline.filter(p=>p.stage==="interview").length;
  const offers=pipeline.filter(p=>p.stage==="offer").length;
  const rejected=pipeline.filter(p=>p.stage==="rejected").length;
  const thirtyDays=Date.now()-30*24*60*60*1000;
  const monthlyApps=pipeline.filter(p=>p.added>thirtyDays).length;
  const followUpsDue=pipeline.filter(p=>p.followup&&p.followup<=today()&&p.stage!=="rejected"&&p.stage!=="offer").length;

  document.getElementById("main-stats").innerHTML=`
    <div class="stat"><div class="stat-l">Active</div><div class="stat-v">${active.length}</div><div class="stat-s">in pipeline</div></div>
    <div class="stat"><div class="stat-l">Interviews</div><div class="stat-v ${interviews>0?"a":""}">${interviews}</div><div class="stat-s">in progress</div></div>
    <div class="stat"><div class="stat-l">Offers</div><div class="stat-v ${offers>0?"g":""}">${offers}</div><div class="stat-s">received</div></div>
    <div class="stat"><div class="stat-l">Monthly apps</div><div class="stat-v ${monthlyApps>=20?"g":monthlyApps>=10?"a":"c"}">${monthlyApps}</div><div class="stat-s">of 20 target</div></div>
    <div class="stat"><div class="stat-l">Follow-ups due</div><div class="stat-v ${followUpsDue>0?"c":""}">${followUpsDue}</div><div class="stat-s">overdue</div></div>
  `;

  const thirtyDayApps=monthlyApps;
  const thirtyDayPct=Math.min(100,Math.round(thirtyDayApps/20*100));
  const rejRate=pipeline.length>0?Math.round(rejected/pipeline.length*100):0;

  document.getElementById("monthly-wrap").innerHTML=`
    <div class="monthly-cell">
      <div class="monthly-label">Applications this month — target 20</div>
      <div class="monthly-bar-meta"><span>${thirtyDayApps} sent</span><span>${thirtyDayPct}%</span></div>
      <div class="monthly-bar-wrap"><div class="monthly-bar-fill" style="width:${thirtyDayPct}%;background:${thirtyDayPct>=100?"var(--gb)":thirtyDayPct>=50?"var(--amber)":"var(--coral)"}"></div></div>
    </div>
    <div class="monthly-cell">
      <div class="monthly-label">Pipeline health — rejection rate</div>
      <div class="monthly-bar-meta"><span>${rejected} rejected of ${pipeline.length} total</span><span>${rejRate}%</span></div>
      <div class="monthly-bar-wrap"><div class="monthly-bar-fill" style="width:${rejRate}%;background:${rejRate<30?"var(--gb)":rejRate<50?"var(--amber)":"var(--coral)"}"></div></div>
    </div>
  `;
}

// ── FUNNEL ────────────────────────────────────────────────
function renderFunnel(){
  const stages=["applied","screen","interview","waiting","offer","rejected"];
  const stageCols={applied:"var(--blue)",screen:"var(--amber)",interview:"var(--purple)",waiting:"var(--coral)",offer:"var(--gb)",rejected:"var(--t3)"};
  document.getElementById("funnel").innerHTML=stages.map(s=>`
    <div class="funnel-stage ${activeFilter===s?"active-filter":""}" onclick="filterStage('${s}')">
      <div class="fs-count" style="color:${stageCols[s]}">${pipeline.filter(p=>p.stage===s).length}</div>
      <div class="fs-label">${STAGE_LABELS[s]}</div>
    </div>
  `).join("");
}

function filterStage(stage){
  activeFilter=activeFilter===stage?"all":stage;
  renderFunnel();renderPipelineList();
}

// ── PIPELINE LIST ─────────────────────────────────────────
function setSort(mode,btn){
  sortMode=mode;
  document.querySelectorAll(".ctrl-btn").forEach(b=>b.classList.remove("active"));
  if(btn)btn.classList.add("active");
  renderPipelineList();
}

function renderPipeline(){
  renderStats();renderFunnel();renderPipelineList();
}

function renderPipelineList(){
  let items=[...pipeline];
  if(activeFilter!=="all")items=items.filter(p=>p.stage===activeFilter);
  if(sortMode==="date")items.sort((a,b)=>b.added-a.added);
  else if(sortMode==="stage")items.sort((a,b)=>(STAGE_ORDER[a.stage]||0)-(STAGE_ORDER[b.stage]||0));
  else if(sortMode==="company")items.sort((a,b)=>a.company.localeCompare(b.company));
  else if(sortMode==="followup")items.sort((a,b)=>(a.followup||"9999")-(b.followup||"9999"));

  const list=document.getElementById("pipe-list");
  if(!items.length){
    list.innerHTML='<div class="empty">No applications yet'+(activeFilter!=="all"?" in this stage":"")+'. Add the first one in the "Add application" tab.</div>';
    return;
  }

  list.innerHTML=items.map(p=>{
    const followupDue=p.followup&&p.followup<=today()&&p.stage!=="rejected"&&p.stage!=="offer";
    const followupSoon=p.followup&&p.followup>today()&&p.followup<=addDays(today(),3)&&p.stage!=="rejected"&&p.stage!=="offer";
    return`
    <div class="pipe-card stage-${p.stage}" id="pc-${p.id}">
      <div class="pipe-header" onclick="toggleCard(${p.id})">
        <div class="priority-dot p-${p.priority||'med'}"></div>
        <div style="flex:1;min-width:0">
          <div class="pipe-company">${p.company}</div>
          <div class="pipe-role">${p.role}${p.type&&p.type!=="other"?' — '+TYPE_LABELS[p.type]:''}</div>
          <div class="pipe-sector">${p.sector||''}</div>
        </div>
        ${followupDue?'<span style="font-size:9px;color:var(--coral);letter-spacing:0.1em;text-transform:uppercase;border:1px solid var(--cbdr);padding:2px 8px;flex-shrink:0">Follow up</span>':''}
        ${followupSoon?'<span style="font-size:9px;color:var(--amber);letter-spacing:0.1em;text-transform:uppercase;border:1px solid var(--abdr);padding:2px 8px;flex-shrink:0">Soon</span>':''}
        <span class="stage-badge badge-${p.stage}">${STAGE_LABELS[p.stage]}</span>
      </div>
      <div class="pipe-body">
        <div class="pipe-meta">
          ${p.dateApplied?`<div class="pm-item"><div class="pm-label">Applied</div><div class="pm-val">${p.dateApplied}</div></div>`:''}
          ${p.followup?`<div class="pm-item"><div class="pm-label">Follow-up</div><div class="pm-val" style="color:${followupDue?'var(--coral)':'var(--t2)'}">${p.followup}</div></div>`:''}
          ${p.contact?`<div class="pm-item"><div class="pm-label">Contact</div><div class="pm-val">${p.contact}</div></div>`:''}
          ${p.contactinfo?`<div class="pm-item"><div class="pm-label">Contact info</div><div class="pm-val" style="word-break:break-all;font-size:11px">${p.contactinfo}</div></div>`:''}
        </div>
        ${p.notes?`<div class="pipe-notes">${p.notes}</div>`:''}
        <div class="btn-row">
          ${["applied","screen","interview","waiting","offer","rejected"].map(s=>`<button class="btn ${p.stage===s?"active-stage":""}" onclick="updateStage(${p.id},'${s}')">${STAGE_LABELS[s]}</button>`).join("")}
          <button class="btn danger" onclick="removeApp(${p.id})">Remove</button>
        </div>
      </div>
    </div>`;
  }).join("");
}

function addDays(dateStr,n){
  const d=new Date(dateStr);d.setDate(d.getDate()+n);return d.toISOString().split("T")[0];
}

function toggleCard(id){document.getElementById("pc-"+id).classList.toggle("open")}

function updateStage(id,stage){
  const p=pipeline.find(p=>p.id===id);
  if(p){p.stage=stage;ss("cp_pipeline",pipeline);renderPipeline();}
}

function removeApp(id){
  if(!confirm("Remove this application?"))return;
  pipeline=pipeline.filter(p=>p.id!==id);ss("cp_pipeline",pipeline);renderPipeline();
}

function addApp(){
  const company=document.getElementById("f-company").value.trim();
  const role=document.getElementById("f-role").value.trim();
  if(!company||!role){alert("Company and role are required.");return;}
  pipeline.push({
    id:Date.now(),
    company,role,
    type:document.getElementById("f-type").value,
    stage:document.getElementById("f-stage").value,
    sector:document.getElementById("f-sector").value,
    priority:document.getElementById("f-priority").value,
    dateApplied:document.getElementById("f-date").value||today(),
    followup:document.getElementById("f-followup").value,
    contact:document.getElementById("f-contact").value.trim(),
    contactinfo:document.getElementById("f-contactinfo").value.trim(),
    notes:document.getElementById("f-notes").value.trim(),
    added:Date.now(),
  });
  ss("cp_pipeline",pipeline);
  ["f-company","f-role","f-contact","f-contactinfo","f-notes","f-date","f-followup"].forEach(id=>document.getElementById(id).value="");
  document.getElementById("f-stage").value="applied";
  document.getElementById("f-priority").value="high";
  renderPipeline();
  document.querySelector('.tnb[data-tab="pipeline"]').click();
}

// ── ROLES ─────────────────────────────────────────────────
function renderRoles(){
  document.getElementById("role-list").innerHTML=ROLE_TARGETS.map(r=>`
    <div class="role-row">
      <div class="role-priority rp-${r.priority}">${r.priority}</div>
      <div><div class="role-name">${r.name}</div><div class="role-why">${r.why}</div></div>
    </div>
  `).join("");
}

// ── SECTORS ───────────────────────────────────────────────
function renderSectors(){
  document.getElementById("sector-grid").innerHTML=SECTORS.map(s=>`
    <div class="sector-card">
      <div class="sector-name">${s.name}</div>
      <div class="sector-why">${s.why}</div>
    </div>
  `).join("");

  const thirtyDays=Date.now()-30*24*60*60*1000;
  const monthApps=pipeline.filter(p=>p.added>thirtyDays).length;
  const active=pipeline.filter(p=>p.stage!=="rejected").length;

  document.getElementById("target-bars").innerHTML=[
    {label:"Applications this month",val:monthApps,target:20,color:"var(--gb)"},
    {label:"Active pipeline size",val:active,target:15,color:"var(--amber)"},
    {label:"Interviews in progress",val:pipeline.filter(p=>p.stage==="interview").length,target:3,color:"var(--purple)"},
  ].map(t=>{
    const pct=Math.min(100,Math.round(t.val/t.target*100));
    return`<div class="target-row">
      <div class="tgt-label">${t.label}</div>
      <div class="tgt-bar-wrap"><div class="tgt-track"><div class="tgt-fill" style="width:${pct}%;background:${t.color}"></div></div></div>
      <div class="tgt-val" style="color:${t.color}">${t.val}/${t.target}</div>
    </div>`;
  }).join("");
}

// ── TEMPLATES ────────────────────────────────────────────
function renderTemplates(){
  document.getElementById("template-list").innerHTML=TEMPLATES.map((t,i)=>`
    <div class="template-card">
      <div class="template-title">${t.title}</div>
      <div class="template-body">${t.body.replace(/\n/g,"<br>")}</div>
      <button class="copy-btn" id="copy-${i}" onclick="copyTemplate(${i})">Copy to clipboard</button>
    </div>
  `).join("");
}

function copyTemplate(i){
  navigator.clipboard.writeText(TEMPLATES[i].body).then(()=>{
    const btn=document.getElementById("copy-"+i);
    btn.textContent="Copied";btn.classList.add("copied");
    setTimeout(()=>{btn.textContent="Copy to clipboard";btn.classList.remove("copied");},2000);
  });
}

// ── EXPORT / IMPORT ───────────────────────────────────────
function exportData(){
  const blob=new Blob([JSON.stringify({pipeline,exported:new Date().toISOString()},null,2)],{type:"application/json"});
  const a=document.createElement("a");a.href=URL.createObjectURL(blob);
  a.download="career_pipeline_"+today()+".json";a.click();
}
function importData(input){
  const file=input.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      const d=JSON.parse(e.target.result);
      if(d.pipeline){ss("cp_pipeline",pipeline=d.pipeline);}
      renderPipeline();alert("Imported.");
    }catch{alert("Invalid file.");}
  };
  reader.readAsText(file);
}

// ── INIT ─────────────────────────────────────────────────
setTimeout(()=>{document.getElementById("loader").classList.add("hidden");},1800);
document.getElementById("f-date").value=today();
renderPipeline();
</script>
</body>
</html>
